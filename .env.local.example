# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Alternative: Use Claude (Anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Alternative: Use Gemini (Google)
# GOOGLE_API_KEY=your-google-api-key-here

# Alternative: Use OpenRouter (Access to 200+ models including GPT-4, Claude, etc.)
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
# OPENROUTER_MODEL=openai/gpt-4-turbo-preview
# Available models: anthropic/claude-3-opus, openai/gpt-4-turbo, google/gemini-pro, etc.
